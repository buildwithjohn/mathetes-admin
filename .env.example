# Copy to .env.local and fill in. Get the URL + keys from the Supabase
# dashboard: Project Settings -> API.
#
# The cloud project for the CCCFSP FUOYE pilot:
NEXT_PUBLIC_SUPABASE_URL=https://jowokfnlfqqjzwhvnmxj.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Public origin of THIS admin app, used to build the staff invite redirect that
# Supabase emails (e.g. https://admin.mathetes.live). Falls back to the request
# host if unset. Add "<this>/auth/callback" to Supabase Auth Redirect URLs.
NEXT_PUBLIC_ADMIN_URL=https://admin.mathetes.live

# Server-only. Required for staff onboarding (creates auth users + sends invite
# emails via the Supabase admin API) and the API routes (verse-image,
# moderation). NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
OPENAI_API_KEY=
# Optional: if set, /api/moderate requires `Authorization: Bearer <this>`
MODERATION_SECRET=

# For local development against `supabase start` instead:
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key
